### Home page
GET {{baseUrl}}/


### Register user cannot self-elevate to admin
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "name": "Bad User",
  "email": "bad@example.com",
  "password": "password123",
  "isAdmin": true
}


### Login user
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{password}}"
}


### Login with wrong password
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "wrongpassword"
}


### Get current user
GET {{baseUrl}}/api/users/me
x-auth-token: {{userToken}}

### Add exercise to workout
POST {{baseUrl}}/api/workouts/{{workoutId}}/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "exercise": "{{exerciseId}}",
  "sets": [
    {
      "reps": 10,
      "kg": 60,
      "type": "warmup"
    },
    {
      "reps": 8,
      "kg": 80,
      "type": "normal"
    }
  ]
}


### Get all exercises
GET {{baseUrl}}/api/exercises


### Create exercise with user token
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "name": "Cable Row Test",
  "muscleGroup": "back",
  "equipment": "cable"
}


### Get exercise by id
GET {{baseUrl}}/api/exercises/{{exerciseId}}


### Update exercise with user token
PUT {{baseUrl}}/api/exercises/{{exerciseId}}
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "name": "Bench Press Test",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Delete exercise with user token should fail
DELETE {{baseUrl}}/api/exercises/{{unusedExerciseId}}
x-auth-token: {{userToken}}


### Delete exercise used in workout with admin token should fail
DELETE {{baseUrl}}/api/exercises/{{exerciseId}}
x-auth-token: {{adminToken}}


### Delete unused exercise with admin token
DELETE {{baseUrl}}/api/exercises/{{unusedExerciseId}}
x-auth-token: {{adminToken}}


### Get all workouts
GET {{baseUrl}}/api/workouts


### Create workout without token should fail
POST {{baseUrl}}/api/workouts
Content-Type: application/json

{
  "title": "No Token Workout",
  "category": "strength",
  "durationMinutes": 45,
  "exercises": []
}


### Create workout with user token
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Push Day HTTP Test",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "{{exerciseId}}",
      "sets": [
        {
          "reps": 10,
          "kg": 60,
          "type": "warmup"
        },
        {
          "reps": 8,
          "kg": 80,
          "type": "normal"
        },
        {
          "reps": 6,
          "kg": 70,
          "type": "dropset"
        }
      ]
    }
  ]
}


### Get workout by id
GET {{baseUrl}}/api/workouts/{{workoutId}}


### Update workout with user token
PUT {{baseUrl}}/api/workouts/{{workoutId}}
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Updated Push Day Test",
  "category": "strength",
  "durationMinutes": 80,
  "exercises": [
    {
      "exercise": "{{exerciseId}}",
      "sets": [
        {
          "reps": 8,
          "kg": 65,
          "type": "warmup"
        },
        {
          "reps": 5,
          "kg": 85,
          "type": "normal"
        }
      ]
    }
  ]
}


### Delete workout with user token should fail
DELETE {{baseUrl}}/api/workouts/{{workoutId}}
x-auth-token: {{userToken}}


### Delete workout with admin token
DELETE {{baseUrl}}/api/workouts/{{workoutId}}
x-auth-token: {{adminToken}}


### Invalid ObjectId for exercise
GET {{baseUrl}}/api/exercises/abc


### Invalid ObjectId for workout
GET {{baseUrl}}/api/workouts/abc


### Existing format but non-existing workout id
GET {{baseUrl}}/api/workouts/000000000000000000000000


### Invalid exercise body
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "name": "Bench Press",
  "muscleGroup": "invalid",
  "equipment": "barbell"
}


### Invalid workout body
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "A",
  "category": "strength",
  "durationMinutes": 45,
  "exercises": []
}


### Workout with invalid referenced exercise id
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Invalid Exercise Reference",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "abc",
      "sets": [
        {
          "reps": 8,
          "kg": 80,
          "type": "normal"
        }
      ]
    }
  ]
}


### Workout with non-existing referenced exercise
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Missing Exercise Reference",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "000000000000000000000000",
      "sets": [
        {
          "reps": 8,
          "kg": 80,
          "type": "normal"
        }
      ]
    }
  ]
}
