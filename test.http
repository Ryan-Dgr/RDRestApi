### Register user
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "name": "Ryan User",
  "email": "ryan@example.com",
  "password": "password123"
}


### Register user cannot self-elevate to admin
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "name": "Bad User",
  "email": "bad@example.com",
  "password": "password123",
  "isAdmin": true
}


### Login user
POST http://localhost:3000/api/auth
Content-Type: application/json

{
  "email": "ryan@example.com",
  "password": "password123"
}


### Login with wrong password
POST http://localhost:3000/api/auth
Content-Type: application/json

{
  "email": "ryan@example.com",
  "password": "wrongpassword"
}


### Get current user
# Replace USER_TOKEN_HERE with token from login response
GET http://localhost:3000/api/users/me
x-auth-token: USER_TOKEN_HERE


### Home page
GET http://localhost:3000/


### Get all exercises
GET http://localhost:3000/api/exercises


### Create exercise with user token
# Replace USER_TOKEN_HERE with token from login response
POST http://localhost:3000/api/exercises
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "name": "Bench Press",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Get exercise by id
# Replace EXERCISE_ID with an _id from create/get-all exercise response
GET http://localhost:3000/api/exercises/EXERCISE_ID


### Update exercise with user token
# Replace USER_TOKEN_HERE and EXERCISE_ID
PUT http://localhost:3000/api/exercises/EXERCISE_ID
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "name": "Bench Press",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Delete exercise with user token should fail
# Replace USER_TOKEN_HERE and EXERCISE_ID
DELETE http://localhost:3000/api/exercises/EXERCISE_ID
x-auth-token: USER_TOKEN_HERE


### Delete exercise with admin token
# Replace ADMIN_TOKEN_HERE and EXERCISE_ID
DELETE http://localhost:3000/api/exercises/EXERCISE_ID
x-auth-token: ADMIN_TOKEN_HERE


### Get all workouts
GET http://localhost:3000/api/workouts


### Create workout without token should fail
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "No Token Workout",
  "category": "strength",
  "durationMinutes": 45,
  "exercises": []
}


### Create workout with user token
# Replace USER_TOKEN_HERE and EXERCISE_ID
POST http://localhost:3000/api/workouts
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "title": "Push Day",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "EXERCISE_ID",
      "sets": 4,
      "reps": 8,
      "kg": 80
    }
  ]
}


### Get workout by id
# Replace WORKOUT_ID with an _id from create/get-all workout response
GET http://localhost:3000/api/workouts/WORKOUT_ID


### Update workout with user token
# Replace USER_TOKEN_HERE, WORKOUT_ID and EXERCISE_ID
PUT http://localhost:3000/api/workouts/WORKOUT_ID
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "title": "Updated Push Day",
  "category": "strength",
  "durationMinutes": 80,
  "exercises": [
    {
      "exercise": "EXERCISE_ID",
      "sets": 5,
      "reps": 5,
      "kg": 85
    }
  ]
}


### Delete workout with user token should fail
# Replace USER_TOKEN_HERE and WORKOUT_ID
DELETE http://localhost:3000/api/workouts/WORKOUT_ID
x-auth-token: USER_TOKEN_HERE


### Delete workout with admin token
# Replace ADMIN_TOKEN_HERE and WORKOUT_ID
DELETE http://localhost:3000/api/workouts/WORKOUT_ID
x-auth-token: ADMIN_TOKEN_HERE


### Invalid ObjectId for exercise
GET http://localhost:3000/api/exercises/abc


### Invalid ObjectId for workout
GET http://localhost:3000/api/workouts/abc


### Existing format but non-existing workout id
GET http://localhost:3000/api/workouts/000000000000000000000000


### Invalid exercise body
POST http://localhost:3000/api/exercises
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "name": "Bench Press",
  "muscleGroup": "invalid",
  "equipment": "barbell"
}


### Invalid workout body
POST http://localhost:3000/api/workouts
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "title": "A",
  "category": "strength",
  "durationMinutes": 45,
  "exercises": []
}


### Workout with invalid referenced exercise id
POST http://localhost:3000/api/workouts
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "title": "Invalid Exercise Reference",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "abc",
      "sets": 4,
      "reps": 8,
      "kg": 80
    }
  ]
}


### Workout with non-existing referenced exercise
POST http://localhost:3000/api/workouts
Content-Type: application/json
x-auth-token: USER_TOKEN_HERE

{
  "title": "Missing Exercise Reference",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "000000000000000000000000",
      "sets": 4,
      "reps": 8,
      "kg": 80
    }
  ]
}
