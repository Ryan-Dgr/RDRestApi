### Home page
GET {{baseUrl}}/

### Register normal user
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "name": "Ryan User",
  "email": "{{userEmail}}",
  "password": "{{password}}"
}


### Login normal user
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{password}}"
}


### Get current user
GET {{baseUrl}}/api/users/me
x-auth-token: {{userToken}}


### Register admin user candidate
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "name": "Admin User",
  "email": "{{adminEmail}}",
  "password": "{{password}}"
}


### Make user admin
# Requires an existing admin token.
# Use MongoDB Compass once to set one user isAdmin=true, then login and paste that token above.
PATCH {{baseUrl}}/api/users/{{adminUserId}}/role
Content-Type: application/json
x-auth-token: {{adminToken}}

{
  "isAdmin": true
}


### Login admin user
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{password}}"
}


### Login with wrong password
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "wrongpassword"
}


### Get all exercises
GET {{baseUrl}}/api/exercises


### Create exercise
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "name": "Bench Press",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Create unused exercise
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "name": "Cable Row",
  "muscleGroup": "back",
  "equipment": "cable"
}


### Get exercise by id
GET {{baseUrl}}/api/exercises/{{exerciseId}}


### Update exercise
PUT {{baseUrl}}/api/exercises/{{exerciseId}}
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "name": "Bench Press Updated",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Invalid exercise body
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "name": "X",
  "muscleGroup": "invalid",
  "equipment": "barbell"
}


### Invalid exercise id
GET {{baseUrl}}/api/exercises/abc


### Get all workouts
GET {{baseUrl}}/api/workouts


### Create workout without token should fail
POST {{baseUrl}}/api/workouts
Content-Type: application/json

{
  "title": "No Token Workout",
  "category": "strength",
  "durationMinutes": 45,
  "exercises": []
}


### Create workout
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Push Day",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "{{exerciseId}}",
      "sets": [
        {
          "reps": 10,
          "kg": 60,
          "type": "warmup"
        },
        {
          "reps": 8,
          "kg": 80,
          "type": "normal"
        }
      ]
    }
  ]
}


### Get workout by id
GET {{baseUrl}}/api/workouts/{{workoutId}}


### Add exercise to workout
POST {{baseUrl}}/api/workouts/{{workoutId}}/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "exercise": "{{exerciseId}}",
  "sets": [
    {
      "reps": 10,
      "kg": 60,
      "type": "warmup"
    }
  ]
}


### Add set to workout exercise
# exerciseEntryId is the _id inside workout.exercises, not the normal exerciseId.
POST {{baseUrl}}/api/workouts/{{workoutId}}/exercises/{{exerciseEntryId}}/sets
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "reps": 6,
  "kg": 90,
  "type": "normal"
}


### Update workout
PUT {{baseUrl}}/api/workouts/{{workoutId}}
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Updated Push Day",
  "category": "strength",
  "durationMinutes": 80,
  "exercises": [
    {
      "exercise": "{{exerciseId}}",
      "sets": [
        {
          "reps": 8,
          "kg": 65,
          "type": "warmup"
        },
        {
          "reps": 5,
          "kg": 85,
          "type": "normal"
        }
      ]
    }
  ]
}


### Invalid workout body
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "A",
  "category": "strength",
  "durationMinutes": 45,
  "exercises": []
}


### Workout with invalid exercise id format
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Invalid Exercise Reference",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "abc",
      "sets": [
        {
          "reps": 8,
          "kg": 80,
          "type": "normal"
        }
      ]
    }
  ]
}


### Workout with non-existing exercise
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Missing Exercise Reference",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "000000000000000000000000",
      "sets": [
        {
          "reps": 8,
          "kg": 80,
          "type": "normal"
        }
      ]
    }
  ]
}


### Invalid workout id
GET {{baseUrl}}/api/workouts/abc


### Get non-existing workout
GET {{baseUrl}}/api/workouts/000000000000000000000000


### Get all workout logs
GET {{baseUrl}}/api/workout-logs
x-auth-token: {{userToken}}


### Create workout log
POST {{baseUrl}}/api/workout-logs
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "workout": "{{workoutId}}",
  "notes": "Strong push session.",
  "exercises": [
    {
      "exercise": "{{exerciseId}}",
      "sets": [
        {
          "reps": 10,
          "kg": 60,
          "type": "warmup"
        },
        {
          "reps": 8,
          "kg": 80,
          "type": "normal"
        }
      ]
    }
  ]
}


### Get workout log by id
GET {{baseUrl}}/api/workout-logs/{{workoutLogId}}
x-auth-token: {{userToken}}


### Update workout log
PUT {{baseUrl}}/api/workout-logs/{{workoutLogId}}
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "workout": "{{workoutId}}",
  "notes": "Updated push session.",
  "exercises": [
    {
      "exercise": "{{exerciseId}}",
      "sets": [
        {
          "reps": 8,
          "kg": 65,
          "type": "warmup"
        },
        {
          "reps": 6,
          "kg": 85,
          "type": "normal"
        },
        {
          "reps": 6,
          "kg": 70,
          "type": "dropset"
        }
      ]
    }
  ]
}


### Invalid workout log id
GET {{baseUrl}}/api/workout-logs/abc
x-auth-token: {{userToken}}


### Invalid workout log body
POST {{baseUrl}}/api/workout-logs
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "workout": "{{workoutId}}",
  "notes": "Missing exercises"
}


### Delete exercise with normal user should fail
DELETE {{baseUrl}}/api/exercises/{{unusedExerciseId}}
x-auth-token: {{userToken}}


### Delete unused exercise with admin
DELETE {{baseUrl}}/api/exercises/{{unusedExerciseId}}
x-auth-token: {{adminToken}}


### Delete exercise used in workout should fail
DELETE {{baseUrl}}/api/exercises/{{exerciseId}}
x-auth-token: {{adminToken}}


### Delete exercise used in workout log should fail
# This only reaches the workout-log check if the exercise is not also used in a workout.
DELETE {{baseUrl}}/api/exercises/{{exerciseId}}
x-auth-token: {{adminToken}}


### Delete workout with normal user should fail
DELETE {{baseUrl}}/api/workouts/{{workoutId}}
x-auth-token: {{userToken}}


### Delete workout used in workout log with admin should fail
DELETE {{baseUrl}}/api/workouts/{{workoutId}}
x-auth-token: {{adminToken}}


### Delete workout log
DELETE {{baseUrl}}/api/workout-logs/{{workoutLogId}}
x-auth-token: {{userToken}}


### Delete workout with admin
DELETE {{baseUrl}}/api/workouts/{{workoutId}}
x-auth-token: {{adminToken}}
