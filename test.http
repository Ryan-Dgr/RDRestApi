### Home page
GET http://localhost:3000/


### Get all exercises
GET http://localhost:3000/api/exercises


### Create exercise: Bench Press
POST http://localhost:3000/api/exercises
Content-Type: application/json

{
  "name": "Bench Press",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Create exercise: Shoulder Press
POST http://localhost:3000/api/exercises
Content-Type: application/json

{
  "name": "Shoulder Press",
  "muscleGroup": "shoulders",
  "equipment": "dumbbell"
}


### Get exercise by id: Bench Press
GET http://localhost:3000/api/exercises/6a0456b1d0d4e48ffe7650b4


### Create invalid exercise: invalid muscle group
POST http://localhost:3000/api/exercises
Content-Type: application/json

{
  "name": "Bench Press",
  "muscleGroup": "chesttt",
  "equipment": "barbell"
}


### Create invalid exercise: invalid equipment
POST http://localhost:3000/api/exercises
Content-Type: application/json

{
  "name": "Bench Press",
  "muscleGroup": "chest",
  "equipment": "car"
}


### Get all workouts
GET http://localhost:3000/api/workouts


### Create workout without exercises
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Push Day",
  "category": "strength",
  "durationMinutes": 75
}


### Create cardio workout without exercises
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Morning Cardio",
  "category": "cardio",
  "durationMinutes": 45
}


### Create workout with exercise references
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Push Day With Exercises",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "6a0456b1d0d4e48ffe7650b4",
      "sets": 4,
      "reps": 8,
      "kg": 80
    },
    {
      "exercise": "6a0456b1d0d4e48ffe7650b5",
      "sets": 3,
      "reps": 10,
      "kg": 22.5
    }
  ]
}


### Get specific workout with populated exercises
GET http://localhost:3000/api/workouts/6a0456b1d0d4e48ffe7650b6


### Update workout with exercise references
PUT http://localhost:3000/api/workouts/6a0456b1d0d4e48ffe7650b6
Content-Type: application/json

{
  "title": "Updated Push Day",
  "category": "strength",
  "durationMinutes": 80,
  "exercises": [
    {
      "exercise": "6a0456b1d0d4e48ffe7650b4",
      "sets": 5,
      "reps": 5,
      "kg": 85
    },
    {
      "exercise": "6a0456b1d0d4e48ffe7650b5",
      "sets": 3,
      "reps": 12,
      "kg": 24
    }
  ]
}


### Delete workout
DELETE http://localhost:3000/api/workouts/6a0456b1d0d4e48ffe7650b6


### Get workout with invalid ObjectId
GET http://localhost:3000/api/workouts/abc


### Get workout with valid ObjectId that does not exist
GET http://localhost:3000/api/workouts/000000000000000000000000


### Update workout with invalid ObjectId
PUT http://localhost:3000/api/workouts/abc
Content-Type: application/json

{
  "title": "Updated Push Day",
  "category": "strength",
  "durationMinutes": 80,
  "exercises": []
}


### Delete workout with invalid ObjectId
DELETE http://localhost:3000/api/workouts/abc


### Create invalid workout: title too short
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "A",
  "category": "strength",
  "durationMinutes": 45
}


### Create invalid workout: invalid category
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Dance Session",
  "category": "dance",
  "durationMinutes": 45
}


### Create invalid workout: duration too high
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Too Long Workout",
  "category": "strength",
  "durationMinutes": 400
}


### Create invalid workout: cardio custom validator
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Very Long Cardio",
  "category": "cardio",
  "durationMinutes": 240
}


### Create invalid workout: invalid exercise ObjectId
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Invalid Exercise Id Workout",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "abc",
      "sets": 4,
      "reps": 8,
      "kg": 80
    }
  ]
}


### Create invalid workout: exercise does not exist
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Missing Exercise Workout",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    {
      "exercise": "000000000000000000000000",
      "sets": 4,
      "reps": 8,
      "kg": 80
    }
  ]
}


### Create valid long strength workout
POST http://localhost:3000/api/workouts
Content-Type: application/json

{
  "title": "Long Strength Session",
  "category": "strength",
  "durationMinutes": 240,
  "exercises": []
}
