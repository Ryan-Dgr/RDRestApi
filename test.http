@baseUrl = http://localhost:3000

# Vul deze waarden aan terwijl je test.
@userEmail = user@example.com
@adminEmail = admin@example.com
@password = wachtwoord

# Kopieer tokens uit de login responses.
@userToken = paste-user-token-here
@adminToken = paste-admin-token-here

@userId = paste-user-id-here
@adminUserId = paste-admin-user-id-here

@exerciseId = paste-exercise-id-here
@secondExerciseId = paste-second-exercise-id-here
@unusedExerciseId = paste-unused-exercise-id-here

@workoutId = paste-workout-id-here
@workoutLogId = paste-workout-log-id-here

# Dit is de _id van een item binnen workoutLog.exercises.
# Dit is dus niet hetzelfde als @exerciseId.
@workoutLogExerciseEntryId = paste-workout-log-exercise-entry-id-here

# Dit is de _id van een set binnen workoutLog.exercises[...].sets.
@workoutLogSetId = paste-workout-log-set-id-here


### Home page
GET {{baseUrl}}/


### Health check
GET {{baseUrl}}/health


### Register normal user
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "name": "Normal User",
  "email": "{{userEmail}}",
  "password": "{{password}}"
}


### Login normal user
# Kopieer de response body naar @userToken.
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{password}}"
}


### Get current user
GET {{baseUrl}}/api/users/me
x-auth-token: {{userToken}}


### Register admin user
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "name": "Admin User",
  "email": "{{adminEmail}}",
  "password": "{{password}}"
}


### Make user admin
# Voor de eerste admin: zet isAdmin=true eenmalig via MongoDB Compass.
# Daarna kan je met een admin token andere users admin maken.
PATCH {{baseUrl}}/api/users/{{adminUserId}}/role
Content-Type: application/json
x-auth-token: {{adminToken}}

{
  "isAdmin": true
}


### Login admin user
# Kopieer de response body naar @adminToken.
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{password}}"
}


### Get all exercises
GET {{baseUrl}}/api/exercises


### Create exercise: Bench Press
# Admin route. Kopieer _id uit de response naar @exerciseId.
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{adminToken}}

{
  "name": "Bench Press",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Create exercise: Cable Row
# Admin route. Kopieer _id uit de response naar @secondExerciseId.
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{adminToken}}

{
  "name": "Cable Row",
  "muscleGroup": "back",
  "equipment": "cable"
}


### Create unused exercise
# Admin route. Kopieer _id uit de response naar @unusedExerciseId.
POST {{baseUrl}}/api/exercises
Content-Type: application/json
x-auth-token: {{adminToken}}

{
  "name": "Bodyweight Squat",
  "muscleGroup": "legs",
  "equipment": "bodyweight"
}


### Get exercise by id
GET {{baseUrl}}/api/exercises/{{exerciseId}}


### Update exercise
# Admin route.
PUT {{baseUrl}}/api/exercises/{{exerciseId}}
Content-Type: application/json
x-auth-token: {{adminToken}}

{
  "name": "Bench Press",
  "muscleGroup": "chest",
  "equipment": "barbell"
}


### Delete unused exercise
# Dit lukt zolang de exercise niet in een workout of workout log gebruikt wordt.
DELETE {{baseUrl}}/api/exercises/{{unusedExerciseId}}
x-auth-token: {{adminToken}}


### Get all workouts
GET {{baseUrl}}/api/workouts


### Create workout
# Workout bevat alleen exercise ids, geen sets.
# Kopieer _id uit de response naar @workoutId.
POST {{baseUrl}}/api/workouts
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Push Day",
  "category": "strength",
  "durationMinutes": 75,
  "exercises": [
    "{{exerciseId}}"
  ]
}


### Add exercise to workout
POST {{baseUrl}}/api/workouts/{{workoutId}}/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "exerciseId": "{{secondExerciseId}}"
}


### Get workout by id
GET {{baseUrl}}/api/workouts/{{workoutId}}


### Update workout
# Ook hier bevat exercises alleen ids.
PUT {{baseUrl}}/api/workouts/{{workoutId}}
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "title": "Push Day Updated",
  "category": "strength",
  "durationMinutes": 80,
  "exercises": [
    "{{exerciseId}}",
    "{{secondExerciseId}}"
  ]
}


### Remove exercise from workout
DELETE {{baseUrl}}/api/workouts/{{workoutId}}/exercises/{{secondExerciseId}}
x-auth-token: {{userToken}}


### Add exercise to workout again
POST {{baseUrl}}/api/workouts/{{workoutId}}/exercises
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "exerciseId": "{{secondExerciseId}}"
}


### Get current user's workout logs
GET {{baseUrl}}/api/workout-logs
x-auth-token: {{userToken}}


### Start workout log
# De server kopieert de exercises uit de workout naar de workout log met sets: [].
# Kopieer _id uit de response naar @workoutLogId.
# Kopieer exercises[0]._id uit de response naar @workoutLogExerciseEntryId.
POST {{baseUrl}}/api/workout-logs
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "workout": "{{workoutId}}",
  "notes": "Strong push session."
}


### Get workout log by id
GET {{baseUrl}}/api/workout-logs/{{workoutLogId}}
x-auth-token: {{userToken}}


### Add set to workout log exercise
# Gebruik hier de _id uit workoutLog.exercises[0]._id.
# Kopieer exercises[0].sets[0]._id uit de response naar @workoutLogSetId.
POST {{baseUrl}}/api/workout-logs/{{workoutLogId}}/exercises/{{workoutLogExerciseEntryId}}/sets
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "reps": 8,
  "kg": 80,
  "type": "normal"
}


### Add another set to workout log exercise
POST {{baseUrl}}/api/workout-logs/{{workoutLogId}}/exercises/{{workoutLogExerciseEntryId}}/sets
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "reps": 10,
  "kg": 60,
  "type": "warmup"
}


### Update set
PUT {{baseUrl}}/api/workout-logs/{{workoutLogId}}/exercises/{{workoutLogExerciseEntryId}}/sets/{{workoutLogSetId}}
Content-Type: application/json
x-auth-token: {{userToken}}

{
  "reps": 6,
  "kg": 90,
  "type": "normal"
}


### Delete set
DELETE {{baseUrl}}/api/workout-logs/{{workoutLogId}}/exercises/{{workoutLogExerciseEntryId}}/sets/{{workoutLogSetId}}
x-auth-token: {{userToken}}


### Get updated workout log
GET {{baseUrl}}/api/workout-logs/{{workoutLogId}}
x-auth-token: {{userToken}}


### Try delete workout while it is used in a workout log
# Verwachte response: 400.
DELETE {{baseUrl}}/api/workouts/{{workoutId}}
x-auth-token: {{adminToken}}


### Try delete used exercise
# Verwachte response: 400 zolang ze in een workout of workout log zit.
DELETE {{baseUrl}}/api/exercises/{{exerciseId}}
x-auth-token: {{adminToken}}


### Delete workout log
DELETE {{baseUrl}}/api/workout-logs/{{workoutLogId}}
x-auth-token: {{userToken}}


### Delete workout
# Dit lukt pas nadat de workout log verwijderd is.
DELETE {{baseUrl}}/api/workouts/{{workoutId}}
x-auth-token: {{adminToken}}
